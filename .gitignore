board/board.json
board/index.json
board/extraction_snapshot.json
board/recon_pending.json

# board server runtime log
.board-server.log
.board-recon.log

# local plugin-reinstall backups (machine state, never ship)
.reinstall-backups/

# Maintainer-only dev tooling — tests, sims, benchmarks, git-hooks, session
# loggers. Never ship to the public plugin/marketplace (it's "dev", not runtime).
dev/

# Added by board-steward — local board data may contain secrets
board/.replay_state.json

# local README preview (gitignored — local-only convenience)
README.preview.html

# local board snapshots (manual saves) — never ship
kept-boards/
